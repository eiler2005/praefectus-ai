---
# ==============================================================================
# vault.yml.example — schema template. Active vault:
#   ansible/group_vars/all/vault.yml  (encrypted with ansible-vault)
# Все секреты — с префиксом vault_*, чтобы было ясно что значение шифровано.
# ==============================================================================

# ===== VPS access (multi-host) =====
# Inventory aliases are non-secret. Real IP/user/port/key live here only.
vault_vps_hosts:
  vps-hetzner-prod:
    ssh_host: "<vps_ip_or_dns>"
    ssh_user: "deploy"
    ssh_port: 22
    ssh_key: "~/.ssh/id_rsa"

  # Fresh Hostkey VPS. Start as root if the provider image only has root,
  # run 00-bootstrap.yml, then switch ssh_user to deploy.
  vps-hostkey-hermes:
    ssh_host: "<hostkey_hermes_ip_or_dns>"
    ssh_user: "root"
    ssh_port: 22
    ssh_key: "~/.ssh/id_ed25519"

# Legacy fallback for older vaults. New entries should go in vault_vps_hosts.
# vault_vps_ssh_host: "<vps_ip_or_dns>"
# vault_vps_ssh_user: "deploy"
# vault_vps_ssh_port: 22
# vault_vps_ssh_key: "~/.ssh/id_rsa"

# ===== Bootstrap (00-bootstrap.yml на свежей VM) =====
# Публичный ключ оператора для добавления в authorized_keys.
vault_deploy_user_pubkey: |
  ssh-ed25519 AAAA...placeholder operator@workstation

# ===== Bastion (опционально, для tunnel-сценариев) =====
vault_bastion_host: "<bastion_lan_ip>"
vault_bastion_user: "admin"
vault_bastion_port: 22

# ===== Trusted IPs (для будущего UFW + fail2ban ignoreip) =====
vault_trusted_ips:
  - "198.51.100.10/32"  # placeholder home WAN

# ===== Cleanup thresholds =====
vault_disk_warn_pct: 80
vault_disk_crit_pct: 90
vault_mem_warn_mb: 500
vault_mem_crit_mb: 200
vault_swap_warn_pct: 60
vault_swap_crit_pct: 80
vault_container_mem_warn_pct: 80
vault_container_mem_crit_pct: 95
vault_oom_lookback_minutes: 10
vault_high_risk_restart_warn: 1
vault_high_risk_containers:
  - "openclaw-openclaw-gateway-1"

# ===== External watchdog =====
# Installed by 20-monitoring.yml on each managed VPS. Each host checks the other
# managed VPS hosts over TCP/SSH and alerts if a target is unreachable.
vault_external_watchdog_timeout_seconds: 5
vault_external_watchdog_fail_after: 2
vault_external_watchdog_dedup_ttl: 900
vault_external_watchdog_probe_mode: "tcp"
vault_external_watchdog_probe_port: 443

# ===== Docker prune filters (только время; volumes никогда автоматом) =====
vault_docker_container_age: "72h"   # остановленные контейнеры старше 3 дней
vault_docker_image_age: "168h"      # неиспользуемые images старше 7 дней
vault_docker_builder_age: "168h"    # build cache старше 7 дней

# ===== Docker resource guardrails (70-docker-limits-critical.yml) =====
# Defaults mirror the current openclaw_firststeps runtime profile for a 2 vCPU /
# 4 GB RAM host. Override here only if the target VPS has a different shape.
# vault_cpu_openclaw_gateway: "0.90"
# vault_mem_openclaw_gateway: "1224m"
# vault_pids_openclaw_gateway: 256
# vault_cpu_omniroute: "0.25"
# vault_mem_omniroute: "512m"
# vault_pids_omniroute: 128
# vault_cpu_lightrag: "0.45"
# vault_mem_lightrag: "1536m"
# vault_pids_lightrag: 128
# vault_cpu_ai_path_cap: "1.60"
# vault_mem_redis: "256m"

# ===== Journal retention =====
vault_journal_keep_time: "14d"
vault_journal_max_size: "500M"

# ===== Expected containers (для 99-verify health check) =====
# name: имя контейнера (docker ps --format '{{.Names}}')
# owner: какой проект отвечает за этот контейнер
# healthcheck: docker | http:<url> | tcp:<host:port>
vault_expected_containers:
  - { name: "deploy-bridge-1",            owner: "maxtg_bridge",        healthcheck: "docker" }
  - { name: "openclaw-gateway",           owner: "openclaw_firststeps", healthcheck: "http://127.0.0.1:18789/healthz" }
  - { name: "lightrag-lightrag-1",         owner: "openclaw_firststeps", healthcheck: "docker" }
  - { name: "fluentloop-bot",              owner: "fluentloop_bot",      healthcheck: "docker" }
  - { name: "omniroute",                  owner: "openclaw_firststeps", healthcheck: "tcp:127.0.0.1:20128" }
  - { name: "telethon-digest-cron-bridge", owner: "openclaw_firststeps", healthcheck: "docker" }
  - { name: "signals-bridge",             owner: "openclaw_firststeps", healthcheck: "tcp:127.0.0.1:8093" }
  - { name: "wiki-import",                owner: "openclaw_firststeps", healthcheck: "tcp:127.0.0.1:8095" }

# ===== Downstream ownership markers =====
# Эти секреты живут в чужих проектах. Здесь только маркер "не наша зона".
# vault_openclaw_telegram_owner_id: см. openclaw_firststeps/LOCAL_ACCESS.md
# vault_router_reality_keys:        см. router_configuration/ansible/secrets/stealth.yml
# vault_maxtg_tg_bot_token:         см. maxtg_bridge/.env.secrets
