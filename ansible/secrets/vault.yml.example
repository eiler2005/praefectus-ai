---
# ==============================================================================
# vault.yml.example — шаблон vault. Реальный vault.yml — encrypted (ansible-vault).
# Все секреты — с префиксом vault_*, чтобы было ясно что значение шифровано.
# ==============================================================================

# ===== VPS access =====
vault_vps_ssh_host: "<vps_ip_or_dns>"
vault_vps_ssh_user: "deploy"
vault_vps_ssh_port: 22
vault_vps_ssh_key: "~/.ssh/id_rsa"

# ===== Bootstrap (для будущего 00-bootstrap.yml на свежей VM) =====
# Публичный ключ оператора для добавления в authorized_keys.
vault_deploy_user_pubkey: |
  ssh-ed25519 AAAA...placeholder operator@workstation

# ===== Bastion (опционально, для tunnel-сценариев) =====
vault_bastion_host: "<bastion_lan_ip>"
vault_bastion_user: "admin"
vault_bastion_port: 22

# ===== Trusted IPs (для будущего UFW + fail2ban ignoreip) =====
vault_trusted_ips:
  - "198.51.100.10/32"  # placeholder home WAN

# ===== Cleanup thresholds =====
vault_disk_warn_pct: 80
vault_disk_crit_pct: 90
vault_mem_warn_mb: 500
vault_mem_crit_mb: 200

# ===== Docker prune filters (только время; volumes никогда автоматом) =====
vault_docker_container_age: "72h"   # остановленные контейнеры старше 3 дней
vault_docker_image_age: "168h"      # неиспользуемые images старше 7 дней
vault_docker_builder_age: "168h"    # build cache старше 7 дней

# ===== Journal retention =====
vault_journal_keep_time: "14d"
vault_journal_max_size: "500M"

# ===== Expected containers (для 99-verify health check) =====
# name: имя контейнера (docker ps --format '{{.Names}}')
# owner: какой проект отвечает за этот контейнер
# healthcheck: docker | http:<url> | tcp:<host:port>
vault_expected_containers:
  - { name: "deploy-bridge-1",            owner: "maxtg_bridge",        healthcheck: "docker" }
  - { name: "openclaw-gateway",           owner: "openclaw_firststeps", healthcheck: "http://127.0.0.1:18789/healthz" }
  - { name: "lightrag",                   owner: "openclaw_firststeps", healthcheck: "http://127.0.0.1:8020/health" }
  - { name: "omniroute",                  owner: "openclaw_firststeps", healthcheck: "tcp:127.0.0.1:20128" }
  - { name: "telethon-digest-cron-bridge", owner: "openclaw_firststeps", healthcheck: "docker" }
  - { name: "signals-bridge",             owner: "openclaw_firststeps", healthcheck: "tcp:127.0.0.1:8093" }
  - { name: "wiki-import",                owner: "openclaw_firststeps", healthcheck: "tcp:127.0.0.1:8095" }

# ===== Downstream ownership markers =====
# Эти секреты живут в чужих проектах. Здесь только маркер "не наша зона".
# vault_openclaw_telegram_owner_id: см. openclaw_firststeps/LOCAL_ACCESS.md
# vault_router_reality_keys:        см. router_configuration/ansible/secrets/stealth.yml
# vault_maxtg_tg_bot_token:         см. maxtg_bridge/.env.secrets
