#!/usr/bin/env bash
# run-check — запускает vps-monitor.py на VPS вручную с Mac.
# Показывает результат в реальном времени.
#
# Usage:
#   ./modules/monitoring/bin/run-check               # health check
#   ./modules/monitoring/bin/run-check --host vps-hostkey-hermes
#   ./modules/monitoring/bin/run-check --test-alert  # тест Telegram
#   ./modules/monitoring/bin/run-check --log         # показать последние 50 строк лога
#   ./modules/monitoring/bin/run-check --status      # статус systemd timer

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
VAULT_FILE="${REPO_ROOT}/ansible/group_vars/all/vault.yml"
SSH_HELPER="${REPO_ROOT}/ansible/scripts/ssh-vps.sh"

# Parse args
ACTION="check"
HOST_ALIAS="${VPS_TARGET:-vps-hetzner-prod}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      HOST_ALIAS="${2:?usage: run-check [--host <inventory-host>] [--test-alert | --log | --status]}"
      shift 2
      continue ;;
    --test-alert) ACTION="test-alert" ;;
    --log)        ACTION="log" ;;
    --status)     ACTION="status" ;;
    --help|-h)
      echo "Usage: run-check [--host <inventory-host>] [--test-alert | --log | --status]"
      exit 0 ;;
    *)
      echo "ERROR: unknown argument: $1" >&2
      exit 2 ;;
  esac
  shift
done

if [[ ! -f "${VAULT_FILE}" ]]; then
  echo "ERROR: vault not found: ${VAULT_FILE}" >&2
  exit 2
fi

case "${ACTION}" in
  check)
    echo "Running health check on ${HOST_ALIAS}..." >&2
    echo ""
    "${SSH_HELPER}" --host "${HOST_ALIAS}" "sudo python3 /usr/local/bin/vps-monitor.py --once"
    ;;
  test-alert)
    echo "Sending test Telegram alert via ${HOST_ALIAS}..." >&2
    echo ""
    "${SSH_HELPER}" --host "${HOST_ALIAS}" "sudo python3 /usr/local/bin/vps-monitor.py --test-alert"
    ;;
  log)
    echo "Last 50 lines of /var/log/vps-monitor.log:" >&2
    echo ""
    "${SSH_HELPER}" --host "${HOST_ALIAS}" \
      "sudo tail -50 /var/log/vps-monitor.log 2>/dev/null || echo '(log not found — monitoring not installed?)'"
    ;;
  status)
    echo "Monitoring timer status on ${HOST_ALIAS}:" >&2
    echo ""
    "${SSH_HELPER}" --host "${HOST_ALIAS}" \
      "systemctl status vps-monitor.timer 2>/dev/null || echo 'timer not found — run: ansible-playbook playbooks/20-monitoring.yml'"
    ;;
esac
