#!/usr/bin/env bash
# secret-scan — сканер утечек VPS-секретов в коммитах vps_management репо.
#
# Ловит:
#   - Реальный VPS IP (из vault, через ansible-vault view)
#   - Любой публичный IPv4 кроме TEST-NET (RFC5737)
#   - SSH private keys (BEGIN ... PRIVATE KEY)
#   - Hardcoded api_key/token/secret паттерны
#
# Игнорирует: ansible/secrets/vault.yml (encrypted), reports/, .git/, .vault_pass*, secrets/
#
# Exit:
#   0 — чисто
#   1 — найдены утечки (печатает path:line:match)
#   2 — ошибка конфигурации (vault недоступен и т.п.)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
cd "${REPO_ROOT}"

VAULT_FILE="ansible/group_vars/all/vault.yml"
VAULT_EXAMPLE="ansible/secrets/vault.yml.example"

# ---------- цвет для вывода ----------
if [[ -t 1 ]]; then
  RED=$'\033[31m'; YELLOW=$'\033[33m'; GREEN=$'\033[32m'; RESET=$'\033[0m'
else
  RED=''; YELLOW=''; GREEN=''; RESET=''
fi

# ---------- получаем известный VPS IP из vault (если доступен) ----------
KNOWN_VPS_IP=""
if [[ -f "${VAULT_FILE}" ]]; then
  if VAULT_CONTENT=$(ansible-vault view "${VAULT_FILE}" 2>/dev/null); then
    KNOWN_VPS_IP=$(echo "${VAULT_CONTENT}" | awk -F'"' '/^vault_vps_ssh_host:/ {print $2; exit}')
  fi
fi

# Какие пути исключаем из скана
EXCLUDES=(
  --exclude-dir='.git'
  --exclude-dir='reports'
  --exclude-dir='secrets'
  --exclude-dir='collections'
  --exclude-dir='__pycache__'
  --exclude-dir='.venv'
  --exclude-dir='venv'
  --exclude-dir='.cache'
  --exclude='vault.yml'
  --exclude='*.backup-*'
  --exclude='.vault_pass*'
)

# Быстрый существующий-IP-check
SCAN_PATHS=(.)

leaks=0

# ---------- 1. конкретный реальный IP из vault ----------
if [[ -n "${KNOWN_VPS_IP}" ]]; then
  if matches=$(grep -RnE --color=never "${EXCLUDES[@]}" "${KNOWN_VPS_IP//./\\.}" "${SCAN_PATHS[@]}" 2>/dev/null); then
    if [[ -n "${matches}" ]]; then
      echo "${RED}LEAK: known VPS IP found:${RESET}"
      echo "${matches}" | sed 's/^/  /'
      leaks=$((leaks + 1))
    fi
  fi
fi

# ---------- 2. SSH private keys ----------
if matches=$(grep -RnE --color=never "${EXCLUDES[@]}" 'BEGIN [A-Z]+ PRIVATE KEY' "${SCAN_PATHS[@]}" 2>/dev/null); then
  if [[ -n "${matches}" ]]; then
    echo "${RED}LEAK: SSH private key material found:${RESET}"
    echo "${matches}" | sed 's/^/  /'
    leaks=$((leaks + 1))
  fi
fi

# ---------- 3. Hardcoded токены / api_key (эвристика) ----------
TOKEN_PATTERN='(api[_-]?key|secret[_-]?key|access[_-]?token|bearer)\s*[:=]\s*["'\''"][a-zA-Z0-9_\-]{20,}'
if matches=$(grep -RnEi --color=never "${EXCLUDES[@]}" "${TOKEN_PATTERN}" "${SCAN_PATHS[@]}" 2>/dev/null); then
  # фильтруем placeholders
  filtered=$(echo "${matches}" | grep -vE 'placeholder|example|YOUR_|<.*>' || true)
  if [[ -n "${filtered}" ]]; then
    echo "${YELLOW}WARN: possible hardcoded token (review):${RESET}"
    echo "${filtered}" | sed 's/^/  /'
    leaks=$((leaks + 1))
  fi
fi

# ---------- результат ----------
if [[ ${leaks} -eq 0 ]]; then
  echo "${GREEN}OK${RESET} — no leaks detected"
  if [[ -z "${KNOWN_VPS_IP}" ]]; then
    echo "  (note: vault not accessible — only generic patterns checked)"
  fi
  exit 0
else
  echo
  echo "${RED}${leaks} leak category(ies) detected. Fix before commit.${RESET}"
  exit 1
fi
