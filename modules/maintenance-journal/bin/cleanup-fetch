#!/usr/bin/env bash
# cleanup-fetch — fetches the canonical periodic cleanup log from VPS,
# parses weekly sessions, aggregates into reports/maintenance/YYYY-MM.md.
#
# Usage:
#   ./modules/maintenance-journal/bin/cleanup-fetch           (current month)
#   ./modules/maintenance-journal/bin/cleanup-fetch --host vps-hostkey-hermes
#   ./modules/maintenance-journal/bin/cleanup-fetch --all     (all months found)
#   ./modules/maintenance-journal/bin/cleanup-fetch --stdout  (print, don't write)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
VAULT_FILE="${REPO_ROOT}/ansible/group_vars/all/vault.yml"
REPORTS_DIR="${REPO_ROOT}/reports/maintenance"
VPS_LOG="/var/log/vps-periodic-cleanup.log"
LEGACY_VPS_LOG="/var/log/vps-weekly-cleanup.log"
SSH_HELPER="${REPO_ROOT}/ansible/scripts/ssh-vps.sh"

WRITE_FILE=1
FILTER_MONTH=""  # empty = current month only; "all" = all months
HOST_ALIAS="${VPS_TARGET:-vps-prod}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      HOST_ALIAS="${2:?usage: cleanup-fetch [--host <inventory-host>] [--all] [--stdout]}"
      shift 2
      ;;
    --all)
      FILTER_MONTH="all"
      shift
      ;;
    --stdout)
      WRITE_FILE=0
      shift
      ;;
    --help|-h)
      echo "Usage: cleanup-fetch [--host <inventory-host>] [--all] [--stdout]"
      exit 0
      ;;
    *)
      echo "ERROR: unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "${FILTER_MONTH}" ]]; then
  FILTER_MONTH="$(date +%Y-%m)"
fi

if [[ ! -f "${VAULT_FILE}" ]]; then
  echo "ERROR: vault not found: ${VAULT_FILE}" >&2
  exit 2
fi

echo "Fetching ${VPS_LOG} from ${HOST_ALIAS}..." >&2

REMOTE_PAYLOAD=$("${SSH_HELPER}" --host "${HOST_ALIAS}" \
  "if sudo test -s ${VPS_LOG}; then echo '__LOG_PATH__ ${VPS_LOG}'; sudo cat ${VPS_LOG}; elif sudo test -s ${LEGACY_VPS_LOG}; then echo '__LOG_PATH__ ${LEGACY_VPS_LOG}'; sudo cat ${LEGACY_VPS_LOG}; else echo '__MISSING__'; fi" 2>/dev/null)

if [[ "${REMOTE_PAYLOAD}" == "__MISSING__" ]] || [[ -z "${REMOTE_PAYLOAD}" ]]; then
  echo "NOTE: ${VPS_LOG} not found or empty on VPS." >&2
  echo "      Legacy fallback ${LEGACY_VPS_LOG} was also missing or empty." >&2
  echo "      Weekly cleanup timer may not have run yet (runs Sundays 03:00 UTC)." >&2
  exit 0
fi

FETCHED_LOG=$(printf '%s\n' "${REMOTE_PAYLOAD}" | sed -n '1s/^__LOG_PATH__ //p')
RAW_LOG=$(printf '%s\n' "${REMOTE_PAYLOAD}" | tail -n +2)

if [[ "${FETCHED_LOG}" == "${LEGACY_VPS_LOG}" ]]; then
  echo "NOTE: using legacy cleanup log ${LEGACY_VPS_LOG}; run 11-periodic-cleanup-setup.yml to retire it." >&2
fi

# ---- Parse sessions (START … END blocks) ----
# Each session looks like:
#   [YYYY-MM-DD HH:MM:SS] === VPS periodic cleanup START ===
#   [YYYY-MM-DD HH:MM:SS] Disk before: N% used
#   ... various output ...
#   [YYYY-MM-DD HH:MM:SS] Disk after: M% used
#   [YYYY-MM-DD HH:MM:SS] Freed: ~XG
#   [YYYY-MM-DD HH:MM:SS] === Weekly cleanup END ===

MONTH_KEYS=()
MONTH_CONTENTS=()

append_month_entry() {
  local month="$1"
  local entry="$2"
  local i

  for ((i = 0; i < ${#MONTH_KEYS[@]}; i++)); do
    if [[ "${MONTH_KEYS[$i]}" == "${month}" ]]; then
      MONTH_CONTENTS[$i]="${MONTH_CONTENTS[$i]}${entry}"
      return
    fi
  done

  MONTH_KEYS+=("${month}")
  MONTH_CONTENTS+=("${entry}")
}

SESSION_LINES=()
IN_SESSION=0

while IFS= read -r line; do
  if echo "${line}" | grep -Eq "=== (Weekly cleanup|VPS periodic cleanup) START ==="; then
    IN_SESSION=1
    SESSION_LINES=("${line}")
  elif echo "${line}" | grep -Eq "=== (Weekly cleanup|VPS periodic cleanup) END ==="; then
    SESSION_LINES+=("${line}")
    IN_SESSION=0

    # Extract session date from first line: [YYYY-MM-DD ...
    SESSION_DATE=$(echo "${SESSION_LINES[0]}" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' | head -1)
    SESSION_MONTH="${SESSION_DATE%%-[0-9][0-9]}"  # YYYY-MM

    if [[ -z "${SESSION_DATE}" ]]; then
      continue
    fi

    # Apply month filter
    if [[ "${FILTER_MONTH}" != "all" && "${SESSION_MONTH}" != "${FILTER_MONTH}" ]]; then
      continue
    fi

    # Parse key metrics from session lines
    DISK_BEFORE=$(printf '%s\n' "${SESSION_LINES[@]}" | grep -i "disk before:" | grep -oE '[0-9]+%' | head -1 || echo "?")
    DISK_AFTER=$(printf '%s\n' "${SESSION_LINES[@]}" | grep -i "disk after:" | grep -oE '[0-9]+%' | head -1 || echo "?")
    FREED=$(printf '%s\n' "${SESSION_LINES[@]}" | grep "Freed:" | sed 's/.*Freed: //' | head -1 || echo "?")
    START_TIME=$(echo "${SESSION_LINES[0]}" | grep -oE '[0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1 || echo "?")
    END_TIME=$(echo "${SESSION_LINES[-1]}" | grep -oE '[0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1 || echo "?")

    # Build entry markdown
    ENTRY="### ${SESSION_DATE} (${START_TIME}–${END_TIME} UTC)"$'\n'
    ENTRY+=""$'\n'
    ENTRY+="| Метрика | Значение |"$'\n'
    ENTRY+="|---|---|"$'\n'
    ENTRY+="| Disk before | ${DISK_BEFORE} |"$'\n'
    ENTRY+="| Disk after  | ${DISK_AFTER} |"$'\n'
    ENTRY+="| Freed       | ${FREED} |"$'\n'
    ENTRY+=""$'\n'

    append_month_entry "${SESSION_MONTH}" "${ENTRY}"
  elif [[ "${IN_SESSION}" -eq 1 ]]; then
    SESSION_LINES+=("${line}")
  fi
done <<< "${RAW_LOG}"

if [[ ${#MONTH_KEYS[@]} -eq 0 ]]; then
  echo "No sessions found for filter: ${FILTER_MONTH}" >&2
  exit 0
fi

# ---- Write or print reports ----
mkdir -p "${REPORTS_DIR}"

for ((i = 0; i < ${#MONTH_KEYS[@]}; i++)); do
  month="${MONTH_KEYS[$i]}"
  REPORT_PATH="${REPORTS_DIR}/${HOST_ALIAS}-${month}.md"
  CONTENT="# Maintenance journal — ${HOST_ALIAS} — ${month}"$'\n\n'
  CONTENT+="Weekly cleanup sessions fetched from \`${HOST_ALIAS}\` (\`${FETCHED_LOG}\`)."$'\n\n'
  CONTENT+="---"$'\n\n'
  CONTENT+="${MONTH_CONTENTS[$i]}"

  if [[ "${WRITE_FILE}" -eq 1 ]]; then
    printf '%s' "${CONTENT}" > "${REPORT_PATH}"
    echo "Written: ${REPORT_PATH}"
  else
    echo "--- ${month} ---"
    printf '%s' "${CONTENT}"
  fi
done
