#!/usr/bin/env bash
# cleanup-fetch — fetches /var/log/vps-weekly-cleanup.log from VPS,
# parses weekly sessions, aggregates into reports/maintenance/YYYY-MM.md.
#
# Usage:
#   ./modules/maintenance-journal/bin/cleanup-fetch           (current month)
#   ./modules/maintenance-journal/bin/cleanup-fetch --all     (all months found)
#   ./modules/maintenance-journal/bin/cleanup-fetch --stdout  (print, don't write)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
VAULT_FILE="${REPO_ROOT}/ansible/group_vars/all/vault.yml"
REPORTS_DIR="${REPO_ROOT}/reports/maintenance"
VPS_LOG="/var/log/vps-weekly-cleanup.log"

WRITE_FILE=1
FILTER_MONTH=""  # empty = current month only; "all" = all months
for arg in "$@"; do
  case "${arg}" in
    --all)    FILTER_MONTH="all" ;;
    --stdout) WRITE_FILE=0 ;;
  esac
done

if [[ -z "${FILTER_MONTH}" ]]; then
  FILTER_MONTH="$(date +%Y-%m)"
fi

# ---- Read vault for SSH credentials ----
if [[ ! -f "${VAULT_FILE}" ]]; then
  echo "ERROR: vault not found: ${VAULT_FILE}" >&2
  exit 2
fi

VAULT_CONTENT=$(ansible-vault view "${VAULT_FILE}")
VPS_HOST=$(echo "${VAULT_CONTENT}" | awk -F'"' '/^vault_vps_ssh_host:/ {print $2; exit}')
VPS_USER=$(echo "${VAULT_CONTENT}" | awk -F'"' '/^vault_vps_ssh_user:/ {print $2; exit}')
VPS_PORT=$(echo "${VAULT_CONTENT}" | awk '/^vault_vps_ssh_port:/ {print $2; exit}')
VPS_PORT="${VPS_PORT:-22}"

if [[ -z "${VPS_HOST}" || -z "${VPS_USER}" ]]; then
  echo "ERROR: vault_vps_ssh_host or vault_vps_ssh_user not set" >&2
  exit 2
fi

SSH_OPTS=(-p "${VPS_PORT}" -o ConnectTimeout=10 -o ServerAliveInterval=15 -o BatchMode=yes)

echo "Fetching ${VPS_LOG} from ${VPS_USER}@${VPS_HOST}:${VPS_PORT}..." >&2

RAW_LOG=$(ssh "${SSH_OPTS[@]}" "${VPS_USER}@${VPS_HOST}" \
  "cat ${VPS_LOG} 2>/dev/null || echo '__MISSING__'" 2>/dev/null)

if [[ "${RAW_LOG}" == "__MISSING__" ]] || [[ -z "${RAW_LOG}" ]]; then
  echo "NOTE: ${VPS_LOG} not found or empty on VPS." >&2
  echo "      Weekly cleanup timer may not have run yet (runs Sundays 03:00 UTC)." >&2
  exit 0
fi

# ---- Parse sessions (START … END blocks) ----
# Each session looks like:
#   [YYYY-MM-DD HH:MM:SS] === Weekly cleanup START ===
#   [YYYY-MM-DD HH:MM:SS] Disk before: N% used
#   ... various output ...
#   [YYYY-MM-DD HH:MM:SS] Disk after: M% used
#   [YYYY-MM-DD HH:MM:SS] Freed: ~XG
#   [YYYY-MM-DD HH:MM:SS] === Weekly cleanup END ===

declare -A MONTH_SESSIONS  # month -> accumulated markdown

SESSION_LINES=()
IN_SESSION=0

while IFS= read -r line; do
  if echo "${line}" | grep -qF "=== Weekly cleanup START ==="; then
    IN_SESSION=1
    SESSION_LINES=("${line}")
  elif echo "${line}" | grep -qF "=== Weekly cleanup END ==="; then
    SESSION_LINES+=("${line}")
    IN_SESSION=0

    # Extract session date from first line: [YYYY-MM-DD ...
    SESSION_DATE=$(echo "${SESSION_LINES[0]}" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' | head -1)
    SESSION_MONTH="${SESSION_DATE%%-[0-9][0-9]}"  # YYYY-MM

    if [[ -z "${SESSION_DATE}" ]]; then
      continue
    fi

    # Apply month filter
    if [[ "${FILTER_MONTH}" != "all" && "${SESSION_MONTH}" != "${FILTER_MONTH}" ]]; then
      continue
    fi

    # Parse key metrics from session lines
    DISK_BEFORE=$(printf '%s\n' "${SESSION_LINES[@]}" | grep "Disk before:" | grep -oE '[0-9]+%' | head -1 || echo "?")
    DISK_AFTER=$(printf '%s\n' "${SESSION_LINES[@]}" | grep "Disk after:" | grep -oE '[0-9]+%' | head -1 || echo "?")
    FREED=$(printf '%s\n' "${SESSION_LINES[@]}" | grep "Freed:" | sed 's/.*Freed: //' | head -1 || echo "?")
    START_TIME=$(echo "${SESSION_LINES[0]}" | grep -oE '[0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1 || echo "?")
    END_TIME=$(echo "${SESSION_LINES[-1]}" | grep -oE '[0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1 || echo "?")

    # Build entry markdown
    ENTRY="### ${SESSION_DATE} (${START_TIME}–${END_TIME} UTC)"$'\n'
    ENTRY+=""$'\n'
    ENTRY+="| Метрика | Значение |"$'\n'
    ENTRY+="|---|---|"$'\n'
    ENTRY+="| Disk before | ${DISK_BEFORE} |"$'\n'
    ENTRY+="| Disk after  | ${DISK_AFTER} |"$'\n'
    ENTRY+="| Freed       | ${FREED} |"$'\n'
    ENTRY+=""$'\n'

    # Accumulate for this month
    MONTH_SESSIONS["${SESSION_MONTH}"]="${MONTH_SESSIONS[${SESSION_MONTH}]:-}${ENTRY}"
  elif [[ "${IN_SESSION}" -eq 1 ]]; then
    SESSION_LINES+=("${line}")
  fi
done <<< "${RAW_LOG}"

if [[ ${#MONTH_SESSIONS[@]} -eq 0 ]]; then
  echo "No sessions found for filter: ${FILTER_MONTH}" >&2
  exit 0
fi

# ---- Write or print reports ----
mkdir -p "${REPORTS_DIR}"

for month in "${!MONTH_SESSIONS[@]}"; do
  REPORT_PATH="${REPORTS_DIR}/${month}.md"
  CONTENT="# Maintenance journal — ${month}"$'\n\n'
  CONTENT+="Weekly cleanup sessions fetched from VPS (\`${VPS_LOG}\`)."$'\n\n'
  CONTENT+="---"$'\n\n'
  CONTENT+="${MONTH_SESSIONS[${month}]}"

  if [[ "${WRITE_FILE}" -eq 1 ]]; then
    printf '%s' "${CONTENT}" > "${REPORT_PATH}"
    echo "Written: ${REPORT_PATH}"
  else
    echo "--- ${month} ---"
    printf '%s' "${CONTENT}"
  fi
done
