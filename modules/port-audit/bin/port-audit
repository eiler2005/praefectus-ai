#!/usr/bin/env python3.12
"""Compare live VPS listeners with docs/ports.md."""

from __future__ import annotations

import argparse
import datetime as dt
import os
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[3]
VAULT_FILE = REPO_ROOT / "ansible/group_vars/all/vault.yml"
PORTS_DOC = REPO_ROOT / "docs/ports.md"
REPORTS_DIR = REPO_ROOT / "reports"


@dataclass(frozen=True)
class ExpectedPort:
    port: str
    protocol: str
    exposure: str
    optional: bool
    source: str

    @property
    def includes_tcp(self) -> bool:
        proto = self.protocol.lower()
        return "tcp" in proto or proto in {"both", "tcp+udp"}


@dataclass(frozen=True)
class LivePort:
    addr: str
    port: str
    process: str

    @property
    def key(self) -> str:
        return f"{self.addr}:{self.port}"

    @property
    def is_public(self) -> bool:
        return self.addr in {"0.0.0.0", "[::]", "::", "*"}


def run(args: list[str], *, input_text: str | None = None) -> str:
    result = subprocess.run(
        args,
        input=input_text,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)
    return result.stdout


def vault_value(vault_text: str, key: str) -> str:
    pattern = re.compile(rf"^{re.escape(key)}:\s*['\"]?([^'\"\n#]+)", re.MULTILINE)
    match = pattern.search(vault_text)
    return match.group(1).strip() if match else ""


def collect_live() -> tuple[list[LivePort], str]:
    if not VAULT_FILE.exists():
        raise SystemExit(f"ERROR: vault not found: {VAULT_FILE}")

    vault_text = run(["ansible-vault", "view", str(VAULT_FILE)])
    host = vault_value(vault_text, "vault_vps_ssh_host")
    user = vault_value(vault_text, "vault_vps_ssh_user")
    port = vault_value(vault_text, "vault_vps_ssh_port") or "22"
    if not host or not user:
        raise SystemExit("ERROR: vault_vps_ssh_host or vault_vps_ssh_user not set")

    sys.stderr.write(f"Collecting port data from {user}@{host}:{port}...\n")
    remote = """
      echo "=== SS_TCP ==="
      ss -tlnp 2>/dev/null || netstat -tlnp 2>/dev/null || echo "ss/netstat n/a"
      echo "=== SS_UDP ==="
      ss -ulnp 2>/dev/null | tail -n +2 || echo "(none)"
      echo "=== DOCKER_PORTS ==="
      docker ps --format "{{.Names}} {{.Ports}}" 2>/dev/null || echo "docker n/a"
    """
    raw = run(
        [
            "ssh",
            "-p",
            port,
            "-o",
            "ConnectTimeout=10",
            "-o",
            "ServerAliveInterval=15",
            "-o",
            "BatchMode=yes",
            f"{user}@{host}",
            remote,
        ]
    )

    tcp = section(raw, "SS_TCP", "SS_UDP")
    docker_ports = section(raw, "DOCKER_PORTS", None)
    live: list[LivePort] = []
    for line in tcp.splitlines():
        if not line.strip() or line.startswith("State "):
            continue
        fields = line.split()
        if len(fields) < 4:
            continue
        addr_port = fields[3]
        process = fields[-1]
        parsed = parse_addr_port(addr_port)
        if parsed:
            addr, port_value = parsed
            live.append(LivePort(addr=addr, port=port_value, process=process))
    return live, docker_ports.strip()


def section(raw: str, start: str, end: str | None) -> str:
    start_marker = f"=== {start} ==="
    if start_marker not in raw:
        return ""
    chunk = raw.split(start_marker, 1)[1]
    if end:
        end_marker = f"=== {end} ==="
        chunk = chunk.split(end_marker, 1)[0]
    return "\n".join(line for line in chunk.splitlines() if not line.startswith("=== "))


def parse_addr_port(value: str) -> tuple[str, str] | None:
    match = re.match(r"^\[(.*)\]:(\d+)$", value)
    if match:
        return f"[{match.group(1)}]", match.group(2)
    match = re.match(r"^(.*):(\d+)$", value)
    if match:
        return match.group(1), match.group(2)
    return None


def parse_expected() -> dict[str, list[ExpectedPort]]:
    if not PORTS_DOC.exists():
        return {}

    expected: dict[str, list[ExpectedPort]] = {}
    current: str | None = None
    for raw_line in PORTS_DOC.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        lower = line.lower()
        if lower.startswith("## public ports") or lower.startswith("## публичные порты"):
            current = "public"
            continue
        if lower.startswith("## restricted ports") or lower.startswith("## ограниченные порты"):
            current = "restricted"
            continue
        if lower.startswith("## private ports") or lower.startswith("## приватные порты"):
            current = "private"
            continue
        if lower.startswith("## internal docker networks") or lower.startswith("## внутренние docker"):
            current = None
            continue
        if current is None or not line.startswith("|"):
            continue
        cells = [cell.strip() for cell in line.strip("|").split("|")]
        if not cells or not re.fullmatch(r"\d+", cells[0]):
            continue
        row_text = " ".join(cells)
        port = cells[0]
        expected.setdefault(port, []).append(
            ExpectedPort(
                port=port,
                protocol=cells[1] if len(cells) > 1 else "TCP",
                exposure=current,
                optional="optional" in row_text.lower(),
                source=row_text,
            )
        )
    return expected


def render_report(live: list[LivePort], docker_ports: str, expected: dict[str, list[ExpectedPort]], ts: str) -> tuple[str, int]:
    issues = 0
    lines: list[str] = [
        f"Port Audit - vps-prod - {ts}",
        "==================================",
        "",
        "Live TCP listeners:",
        f"{'Address:Port':25} Process",
        f"{'------------':25} -------",
    ]
    for item in sorted(live, key=lambda item: (item.port, item.addr)):
        lines.append(f"{item.key:25} {item.process}")
    lines.append("")

    by_port: dict[str, list[LivePort]] = {}
    for item in live:
        by_port.setdefault(item.port, []).append(item)

    lines.append("Security checks:")
    unsafe: list[str] = []
    for item in live:
        expected_rows = expected.get(item.port, [])
        if any(row.exposure == "private" for row in expected_rows) and item.is_public:
            unsafe.append(f"UNSAFE BINDING: port {item.port} should be private but is on {item.addr}")
        if any(row.exposure == "restricted" for row in expected_rows) and item.is_public:
            unsafe.append(f"UNSAFE BINDING: port {item.port} should be restricted but is on {item.addr}")
    if unsafe:
        issues += len(unsafe)
        lines.extend(f"  {line}" for line in unsafe)
    else:
        lines.append("  OK - no unsafe public bindings detected")
    lines.append("")

    lines.append("New/unexpected ports (not in docs/ports.md):")
    new_found = False
    for item in sorted(live, key=lambda item: (item.port, item.addr)):
        if item.port not in expected:
            new_found = True
            lines.append(f"  NEW: {item.key} ({item.process})")
            if item.is_public:
                issues += 1
    if not new_found:
        lines.append("  OK - all listeners match docs/ports.md")
    lines.append("")

    lines.append("Missing expected ports:")
    missing_found = False
    for port, rows in sorted(expected.items(), key=lambda pair: int(pair[0])):
        if port in by_port:
            continue
        required_rows = [row for row in rows if not row.optional and row.includes_tcp]
        if not required_rows:
            continue
        missing_found = True
        lines.append(f"  MISSING: port {port} (expected in docs/ports.md)")
    if not missing_found:
        lines.append("  OK - all required expected ports are listening")
    lines.append("")

    lines.append("Docker container port bindings:")
    lines.append(docker_ports or "(none)")
    lines.append("")
    lines.append("==================================")
    if issues:
        lines.append(f"RESULT: {issues} issue(s) found - see above")
    else:
        lines.append("RESULT: OK - no issues found")
    lines.append("==================================")
    return "\n".join(lines) + "\n", issues


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--save", action="store_true")
    parser.add_argument("--live-only", action="store_true")
    args = parser.parse_args()

    live, docker_ports = collect_live()
    if args.live_only:
        print("")
        print("=== Live TCP listeners ===")
        print(f"{'Address:Port':25} Process")
        print(f"{'------------':25} -------")
        for item in sorted(live, key=lambda item: (item.port, item.addr)):
            print(f"{item.key:25} {item.process}")
        print("")
        print("=== Docker port bindings ===")
        print(docker_ports)
        return 0

    ts = dt.datetime.now(dt.UTC).strftime("%Y%m%dT%H%M%S")
    report, issues = render_report(live, docker_ports, parse_expected(), ts)
    print(report)
    if args.save:
        REPORTS_DIR.mkdir(parents=True, exist_ok=True)
        path = REPORTS_DIR / f"port-audit-{ts}.txt"
        path.write_text(report, encoding="utf-8")
        sys.stderr.write(f"Report saved: {path}\n")
    return 1 if issues else 0


if __name__ == "__main__":
    raise SystemExit(main())
