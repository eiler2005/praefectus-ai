#!/usr/bin/env bash
# disk-report — standalone отчёт по диску VPS (без ansible).
# Читает host из vault, ходит SSH, собирает df/du/docker df, печатает + сохраняет в reports/.
#
# Использование:
#   ./modules/disk-observatory/bin/disk-report
#   ./modules/disk-observatory/bin/disk-report --host vps-hostkey-hermes
#   ./modules/disk-observatory/bin/disk-report --no-save  (только stdout, без файла)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
VAULT_FILE="${REPO_ROOT}/ansible/group_vars/all/vault.yml"
REPORTS_DIR="${REPO_ROOT}/reports"
SSH_HELPER="${REPO_ROOT}/ansible/scripts/ssh-vps.sh"

SAVE_REPORT=1
HOST_ALIAS="${VPS_TARGET:-vps-prod}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      HOST_ALIAS="${2:?usage: disk-report [--host <inventory-host>] [--no-save]}"
      shift 2
      ;;
    --no-save)
      SAVE_REPORT=0
      shift
      ;;
    --help|-h)
      echo "Usage: disk-report [--host <inventory-host>] [--no-save]"
      exit 0
      ;;
    *)
      echo "ERROR: unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ ! -f "${VAULT_FILE}" ]]; then
  echo "ERROR: vault not found at ${VAULT_FILE}" >&2
  echo "       Copy ansible/secrets/vault.yml.example → ansible/group_vars/all/vault.yml, fill values, ansible-vault encrypt." >&2
  exit 2
fi

# Запускаем удалённый сбор данных
REMOTE_REPORT=$("${SSH_HELPER}" --host "${HOST_ALIAS}" 'bash -s' <<'REMOTE_EOF'
set -euo pipefail
echo "## df -h /"
df -h /
echo
echo "## df -ih /"
df -ih /
echo
echo "## free -h"
free -h
echo
echo "## /proc/loadavg"
cat /proc/loadavg
echo
echo "## du -sh top dirs"
sudo du -xhd1 / /var /opt /home /root 2>/dev/null | sort -hr | head -50
echo
echo "## docker system df"
docker system df 2>/dev/null || echo "docker not installed or not accessible"
echo
echo "## docker active images"
docker ps -q 2>/dev/null \
  | xargs -r docker inspect --format '{{.Name}} {{.Config.Image}} {{.Image}}' 2>/dev/null \
  | sed 's#^/##' \
  || echo "docker not installed or not accessible"
echo
echo "## docker images by created date"
docker images --format '{{.ID}} {{.CreatedAt}} {{.Size}} {{.Repository}}:{{.Tag}}' 2>/dev/null | sort -k2r | head -80 || echo "docker not installed or not accessible"
echo
echo "## docker ghostroute rollback images"
docker images --format '{{.ID}} {{.CreatedAt}} {{.Size}} {{.Repository}}:{{.Tag}}' 2>/dev/null \
  | awk '$0 ~ /ghostroute-console:(rollback-|[0-9a-f]{7,})/ {print}' \
  | sort -k2r \
  || echo "docker not installed or not accessible"
echo
echo "## journalctl --disk-usage"
journalctl --disk-usage 2>/dev/null || echo "journalctl unavailable"
echo
echo "## apt cache"
du -sh /var/cache/apt/archives 2>/dev/null || echo "0"
echo
echo "## Files >100M (top 50)"
sudo find / -xdev -type f -size +100M -printf '%s %p\n' 2>/dev/null | sort -nr | head -50
echo
echo "## App-owned review candidates (do not auto-delete)"
sudo find /opt/ghostroute-console/data/backups -xdev -type f -printf '%s %p\n' 2>/dev/null | sort -nr | head -20 || true
echo
echo "## docker dangling volumes"
docker volume ls -f dangling=true 2>/dev/null || echo "n/a"
REMOTE_EOF
)

TS=$(date -u +%Y%m%dT%H%M%SZ)
HEADER="# Disk report — ${HOST_ALIAS} — ${TS}"

OUTPUT="${HEADER}

\`\`\`
${REMOTE_REPORT}
\`\`\`
"

echo "${OUTPUT}"

if [[ ${SAVE_REPORT} -eq 1 ]]; then
  mkdir -p "${REPORTS_DIR}"
  REPORT_PATH="${REPORTS_DIR}/disk-report-${TS}.md"
  printf '%s\n' "${OUTPUT}" > "${REPORT_PATH}"
  echo
  echo "Saved: ${REPORT_PATH}"
fi
